---
/**
 * 配信カード — 單場直播的セトリ。
 */
import type { VideoEntry } from "../lib/data";

interface Props {
  video: VideoEntry;
}

const { video } = Astro.props;
const date = video.publishedAt.slice(0, 10);
const ytUrl = `https://www.youtube.com/watch?v=${video.videoId}`;
---

<div class="border border-border rounded-lg p-4 hover:shadow-sm transition-shadow">
  <details>
    <summary class="cursor-pointer">
      <div class="flex items-center justify-between gap-2">
        <div class="flex-1 min-w-0">
          <span class="text-xs text-text-muted">{date}</span>
          <h3 class="font-medium text-sm truncate mt-0.5">{video.title.slice(0, 60)}</h3>
        </div>
        <span class="shrink-0 inline-flex items-center justify-center px-2 h-6 rounded-full bg-primary/10 text-primary text-xs font-bold">
          {video.songs.length} 曲
        </span>
      </div>
    </summary>
    <div class="mt-3 space-y-1 border-t border-border pt-3">
      {video.songs.map((song, i) => (
        <div class="flex items-center gap-2 text-sm">
          <span class="w-14 text-text-muted text-xs shrink-0 text-right">{song.timestamp}</span>
          <a
            href={song.url}
            target="_blank"
            rel="noopener"
            data-play
            data-video-id={video.videoId}
            data-start={String(song.seconds)}
            data-title={song.title}
            data-artist={song.artist}
            data-date={date}
            class="text-primary hover:text-primary-dark"
          >
            {song.title}
          </a>
          {song.artist && (
            <span class="text-text-muted text-xs">/ {song.artist}</span>
          )}
        </div>
      ))}
      <div class="pt-2 text-xs">
        <a href={ytUrl} target="_blank" rel="noopener" class="text-text-muted hover:text-primary" data-i18n="video.youtube">
          在 YouTube 觀看
        </a>
      </div>
    </div>
  </details>
</div>
