---
/**
 * PlayerBar — 固定底部 YouTube 嵌入播放列。
 *
 * 功能: 播放/暫停、進度條、影片縮圖、外開 YouTube、關閉。
 * 背景色依頻道代表色動態變換。
 * 使用 YouTube IFrame Player API。
 * Progressive enhancement: JS 失敗時連結直接跳 YouTube。
 */
import { getChannels } from "../lib/data";

const channels = getChannels();
const colorMap: Record<string, { bg: string; accent: string }> = {};
for (const ch of channels) {
  if (ch.color) {
    colorMap[ch.channelId] = {
      bg: ch.color,
      accent: ch.colorSecondary || "#e40079",
    };
  }
}
---

<div
  id="player-bar"
  class="fixed bottom-0 left-0 right-0 z-50 translate-y-full transition-all duration-300"
  style="background-color: #5e2a89;"
>
  <!-- Progress bar (top edge) -->
  <div class="h-1 bg-white/10 cursor-pointer" id="progress-track">
    <div class="h-full transition-[width] duration-200" id="progress-fill" style="width: 0%; background-color: #e40079;"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-2 flex items-center gap-3 text-sm" style="color: inherit;">
    <!-- Thumbnail -->
    <img
      id="player-thumb"
      src=""
      alt=""
      class="w-10 h-10 rounded object-cover shrink-0 hidden"
    />

    <!-- Play/Pause -->
    <button id="btn-play" class="p-2 hover:bg-white/10 rounded-full transition-colors shrink-0" title="Play/Pause">
      <svg id="icon-play" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      <svg id="icon-pause" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </button>

    <!-- Song info -->
    <div class="flex-1 min-w-0">
      <div class="truncate">
        <span id="player-title" class="font-medium">—</span>
        <span id="player-artist" class="ml-1 opacity-70"></span>
      </div>
      <div class="text-xs opacity-70 truncate">
        <span id="player-date"></span>
      </div>
    </div>

    <!-- Time -->
    <div class="text-xs opacity-70 shrink-0 font-mono" id="player-time"></div>

    <!-- Volume -->
    <div class="flex items-center gap-1 shrink-0">
      <button id="btn-mute" class="p-1 hover:bg-white/10 rounded-full transition-colors" title="Mute">
        <svg id="icon-vol" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
        <svg id="icon-muted" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
      </button>
      <input
        type="range"
        id="volume-slider"
        min="0"
        max="100"
        value="80"
        class="w-16 h-1 rounded-full cursor-pointer volume-track"
      />
    </div>

    <!-- Open in YouTube -->
    <a id="btn-youtube" href="#" target="_blank" rel="noopener" class="p-1.5 hover:bg-white/10 rounded-full transition-colors shrink-0" title="Open in YouTube">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14 3v2h3.59l-9.3 9.29 1.42 1.42L19 6.41V10h2V3h-7zM5 5v14h14v-7h-2v5H7V7h5V5H5z"/>
      </svg>
    </a>

    <!-- Close -->
    <button id="btn-close" class="p-1.5 hover:bg-white/10 rounded-full transition-colors shrink-0" title="Close">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Hidden YouTube player mount -->
  <div id="yt-player" class="absolute w-0 h-0 overflow-hidden"></div>
</div>

<style>
  .volume-track {
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    border-radius: 9999px;
    background: var(--volume-track-color, rgba(255,255,255,0.3));
  }
  .volume-track::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: currentColor;
    cursor: pointer;
  }
  .volume-track::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: currentColor;
    border: none;
    cursor: pointer;
  }
  .volume-track::-moz-range-track {
    height: 4px;
    border-radius: 9999px;
    background: var(--volume-track-color, rgba(255,255,255,0.3));
  }
</style>

<script is:inline define:vars={{ colorMap }}>
  // --- Types ---
  // TrackInfo: { videoId, start, title, artist, date }

  // --- State ---
  let player = null;
  let isReady = false;
  let isPlaying = false;
  let currentTrack = null;
  let progressTimer = null;

  // --- DOM ---
  const bar = document.getElementById("player-bar");
  const btnPlay = document.getElementById("btn-play");
  const btnClose = document.getElementById("btn-close");
  const btnYoutube = document.getElementById("btn-youtube");
  const iconPlay = document.getElementById("icon-play");
  const iconPause = document.getElementById("icon-pause");
  const titleEl = document.getElementById("player-title");
  const artistEl = document.getElementById("player-artist");
  const dateEl = document.getElementById("player-date");
  const timeEl = document.getElementById("player-time");
  const thumbEl = document.getElementById("player-thumb");
  const progressTrack = document.getElementById("progress-track");
  const progressFill = document.getElementById("progress-fill");
  const btnMute = document.getElementById("btn-mute");
  const iconVol = document.getElementById("icon-vol");
  const iconMuted = document.getElementById("icon-muted");
  const volumeSlider = document.getElementById("volume-slider");
  var isMuted = false;
  var savedVolume = 80;

  // --- Channel color detection ---
  function detectChannelId() {
    // Try to get channelId from page URL or data
    const path = window.location.pathname.replace(/^\//, "").replace(/\/$/, "");
    if (path.startsWith("UC") && path.length >= 20) return path;
    // Fallback: check meta or first key in colorMap
    const keys = Object.keys(colorMap);
    return keys.length === 1 ? keys[0] : "";
  }

  function isLightColor(hex) {
    var r = parseInt(hex.slice(1, 3), 16);
    var g = parseInt(hex.slice(3, 5), 16);
    var b = parseInt(hex.slice(5, 7), 16);
    var luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
    return luminance > 0.6;
  }

  function applyChannelColor(videoId) {
    var channelId = detectChannelId();
    var entry = colorMap[channelId];
    if (entry) {
      bar.style.backgroundColor = entry.bg;
      progressFill.style.backgroundColor = entry.accent;
      volumeSlider.style.setProperty("--volume-track-color", entry.accent);
      var textColor = isLightColor(entry.bg) ? "#1a1a1a" : "#ffffff";
      bar.style.color = textColor;
    } else {
      bar.style.backgroundColor = "#5e2a89";
      bar.style.color = "#ffffff";
      progressFill.style.backgroundColor = "#e40079";
      volumeSlider.style.setProperty("--volume-track-color", "rgba(255,255,255,0.3)");
    }
  }

  // --- YouTube IFrame API ---
  function loadYTApi() {
    if (document.getElementById("yt-api-script")) return;
    const tag = document.createElement("script");
    tag.id = "yt-api-script";
    tag.src = "https://www.youtube.com/iframe_api";
    document.head.appendChild(tag);
  }

  window.onYouTubeIframeAPIReady = function() {
    player = new YT.Player("yt-player", {
      height: "0",
      width: "0",
      playerVars: {
        autoplay: 0,
        controls: 0,
        disablekb: 1,
        modestbranding: 1,
        rel: 0,
      },
      events: {
        onReady: function() { isReady = true; },
        onStateChange: onStateChange,
        onError: onError,
      },
    });
  };

  function onStateChange(e) {
    if (e.data === YT.PlayerState.PLAYING) {
      isPlaying = true;
      updatePlayIcon();
      startProgress();
    } else if (e.data === YT.PlayerState.PAUSED) {
      isPlaying = false;
      updatePlayIcon();
      stopProgress();
    } else if (e.data === YT.PlayerState.ENDED) {
      isPlaying = false;
      updatePlayIcon();
      stopProgress();
    }
  }

  function onError(e) {
    if (e.data === 150 || e.data === 101) {
      if (currentTrack) {
        const url = "https://youtu.be/" + currentTrack.videoId + "?t=" + currentTrack.start;
        window.open(url, "_blank");
      }
    }
  }

  // --- Play control ---
  function playTrack(track) {
    loadYTApi();
    currentTrack = track;
    updateUI(track);
    applyChannelColor(track.videoId);
    showBar();

    if (isReady && player) {
      player.loadVideoById({
        videoId: track.videoId,
        startSeconds: track.start,
      });
      player.setVolume(parseInt(volumeSlider.value));
    } else {
      var check = setInterval(function() {
        if (isReady && player) {
          clearInterval(check);
          player.loadVideoById({
            videoId: track.videoId,
            startSeconds: track.start,
          });
          player.setVolume(parseInt(volumeSlider.value));
        }
      }, 200);
    }
  }

  function togglePlay() {
    if (!player || !isReady) return;
    if (isPlaying) {
      player.pauseVideo();
    } else {
      player.playVideo();
    }
  }

  function closePlayer() {
    if (player && isReady) {
      player.stopVideo();
    }
    isPlaying = false;
    updatePlayIcon();
    stopProgress();
    hideBar();
    document.body.style.paddingBottom = "";
  }

  // --- UI ---
  function updateUI(track) {
    titleEl.textContent = track.title || "—";
    artistEl.textContent = track.artist ? "/ " + track.artist : "";
    dateEl.textContent = track.date || "";
    progressFill.style.width = "0%";
    timeEl.textContent = "";
    btnYoutube.href = track.start
      ? "https://youtu.be/" + track.videoId + "?t=" + track.start
      : "https://youtu.be/" + track.videoId;

    // Thumbnail
    var thumbUrl = "https://img.youtube.com/vi/" + track.videoId + "/default.jpg";
    thumbEl.src = thumbUrl;
    thumbEl.classList.remove("hidden");
  }

  function updatePlayIcon() {
    iconPlay.classList.toggle("hidden", isPlaying);
    iconPause.classList.toggle("hidden", !isPlaying);
  }

  function showBar() {
    bar.classList.remove("translate-y-full");
    bar.classList.add("translate-y-0");
    document.body.style.paddingBottom = "72px";
  }

  function hideBar() {
    bar.classList.remove("translate-y-0");
    bar.classList.add("translate-y-full");
  }

  function formatTime(sec) {
    var m = Math.floor(sec / 60);
    var s = Math.floor(sec % 60);
    return m + ":" + String(s).padStart(2, "0");
  }

  // --- Progress ---
  function startProgress() {
    stopProgress();
    progressTimer = setInterval(function() {
      if (!player || !isReady || !isPlaying) return;
      var current = player.getCurrentTime() || 0;
      var duration = player.getDuration() || 1;
      var pct = (current / duration) * 100;
      progressFill.style.width = pct + "%";
      timeEl.textContent = formatTime(current) + " / " + formatTime(duration);
    }, 1000);
  }

  function stopProgress() {
    if (progressTimer) {
      clearInterval(progressTimer);
      progressTimer = null;
    }
  }

  // --- Progress bar click (seek) ---
  progressTrack.addEventListener("click", function(e) {
    if (!player || !isReady) return;
    var rect = progressTrack.getBoundingClientRect();
    var pct = (e.clientX - rect.left) / rect.width;
    var duration = player.getDuration() || 0;
    player.seekTo(pct * duration, true);
  });

  // --- Button events ---
  btnPlay.addEventListener("click", togglePlay);
  btnClose.addEventListener("click", closePlayer);

  // --- Volume ---
  volumeSlider.addEventListener("input", function() {
    var vol = parseInt(volumeSlider.value);
    if (player && isReady) player.setVolume(vol);
    isMuted = vol === 0;
    iconVol.classList.toggle("hidden", isMuted);
    iconMuted.classList.toggle("hidden", !isMuted);
    if (vol > 0) savedVolume = vol;
  });

  btnMute.addEventListener("click", function() {
    if (isMuted) {
      volumeSlider.value = savedVolume;
      if (player && isReady) player.setVolume(savedVolume);
      isMuted = false;
    } else {
      savedVolume = parseInt(volumeSlider.value) || 80;
      volumeSlider.value = 0;
      if (player && isReady) player.setVolume(0);
      isMuted = true;
    }
    iconVol.classList.toggle("hidden", isMuted);
    iconMuted.classList.toggle("hidden", !isMuted);
  });

  // --- Global click delegate for [data-play] ---
  document.addEventListener("click", function(e) {
    var link = e.target.closest("[data-play]");
    if (!link) return;
    e.preventDefault();

    var track = {
      videoId: link.dataset.videoId || "",
      start: parseInt(link.dataset.start || "0", 10),
      title: link.dataset.title || "",
      artist: link.dataset.artist || "",
      date: link.dataset.date || "",
    };

    playTrack(track);
  });
</script>
