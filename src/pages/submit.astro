    </div>

    <!-- Video type selector -->
    <div id="type-selector" class="mb-4 hidden">
      <label class="block text-sm font-medium mb-2" data-i18n="submit.type_label">йЎһеһӢ</label>
      <div class="flex gap-2 flex-wrap">
        <button data-type-btn="stream" class="type-btn px-3 py-1.5 text-xs rounded-full border border-border hover:border-primary transition-colors" data-i18n="submit.type_stream">
          зӣҙж’ӯжӯҢеӣһ
        </button>
        <button data-type-btn="cover" class="type-btn px-3 py-1.5 text-xs rounded-full border border-border hover:border-primary transition-colors" data-i18n="submit.type_cover">
          жҠ•зЁҝеӢ•з•«
        </button>
        <button data-type-btn="original" class="type-btn px-3 py-1.5 text-xs rounded-full border border-border hover:border-primary transition-colors" data-i18n="submit.type_original">
          еҺҹеүөжӣІ
        </button>
        <button data-type-btn="short" class="type-btn px-3 py-1.5 text-xs rounded-full border border-border hover:border-primary transition-colors">
          Short
        </button>
      </div>
    </div>

    <!-- Single song auto-detect (for cover/original/short) -->
    <div id="single-song-section" class="mb-4 hidden">
      <div class="p-4 border border-border rounded-lg bg-border/10">
        <p class="text-sm text-text-muted mb-2" data-i18n="submit.auto_detected">иҮӘеӢ•еҒөжё¬зӮәе–®жӣІжҠ•зЁҝпјҡ</p>
        <div class="flex items-center gap-3">
          <span id="auto-song" class="font-medium"></span>
          <span id="auto-artist" class="text-text-muted">/</span>
        </div>
      </div>
    </div>

    <!-- Setlist text (for streams only) -->
    <div id="setlist-section" class="mb-4 hidden">
      <label class="block text-sm font-medium mb-1" data-i18n="submit.setlist_label">жӣІзӣ®жё…е–®пјҲжҜҸиЎҢдёҖжӣІпјү</label>
      <textarea
        id="input-setlist"
        rows="10"
        placeholder="00:03:25 жӣІеҗҚA / жӯҢжүӢA&#10;00:08:12 жӣІеҗҚB / жӯҢжүӢB&#10;00:15:40 жӣІеҗҚC / жӯҢжүӢC"
        class="w-full px-4 py-2 border border-border rounded-lg text-sm font-mono focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
      ></textarea>
      <button
        id="btn-preview"
        class="mt-2 px-6 py-2 rounded-full text-sm font-medium text-white transition-colors"
        style="background: linear-gradient(135deg, #5e2a89, #e40079);"
        data-i18n="submit.preview_btn"
      >
        й җиҰҪи§Јжһҗ
      </button>
    </div>

    <!-- Preview table -->
    <div id="preview-section" class="hidden mb-6">
      <h3 class="font-bold mb-2" data-i18n="submit.preview_title">и§Јжһҗзөҗжһң</h3>
      <p id="preview-count" class="text-sm text-text-muted mb-2"></p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-primary/20 text-left">
              <th class="py-1 px-2 w-20" data-i18n="submit.col_time">жҷӮй–“</th>
              <th class="py-1 px-2" data-i18n="submit.col_song">жӣІеҗҚ</th>
              <th class="py-1 px-2" data-i18n="submit.col_artist">жӯҢжүӢ</th>
            </tr>
          </thead>
          <tbody id="preview-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Submit button -->
    <button
      id="btn-submit"
      class="hidden px-6 py-2 rounded-full text-sm font-medium text-white transition-colors"
      style="background: linear-gradient(135deg, #5e2a89, #e40079);"
      data-i18n="submit.submit_btn"
    >
      жҸҗдәӨпјҲе»әз«Ӣ Issueпјү
    </button>
  </div>

  <script is:inline define:vars={{ GITHUB_REPO, channelNames, channelMap, songAliases, artistAliases }}>
    // --- Light normalizer (mirrors Python normalizer's most impactful rules) ---
    var QUOTE_CHARS = /^[гҖҢгҖҚгҖҺгҖҸ""'']+|[гҖҢгҖҚгҖҺгҖҸ""'']+$/g;
    var FEAT_PAREN_RE = /\s*[\(пјҲ]feat\.?\s+.+?[\)пјү]\s*$/i;
    var FEAT_RE = /\s+feat\.?\s+.+$/i;

    function normalizeText(text, isTitle) {
      // NFKC (fullwidth вҶ’ halfwidth etc.)
      text = text.normalize("NFKC");
      // Remove zero-width characters
      text = text.replace(/[\u200B-\u200D\uFEFF\u00AD\u2060\u180E]/g, "");
      // Wave dash вҶ’ ASCII tilde
      text = text.replace(/\u301C/g, "~").replace(/\uFF5E/g, "~");
      // Strip + collapse whitespace
      text = text.trim().replace(/\s+/g, " ");
      // Remove quotes
      text = text.replace(QUOTE_CHARS, "");
      if (isTitle) {
        // Remove (feat. xxx) and feat. xxx from titles
        text = text.replace(FEAT_PAREN_RE, "");
        text = text.replace(FEAT_RE, "");
      }
      return text.trim();
    }

    function normalizeSong(title, artist) {
      title = normalizeText(title, true);
      artist = normalizeText(artist, false);
      // Alias lookup
      var ct = songAliases[title.toLowerCase()];
      if (ct) title = ct;
      var ca = artistAliases[artist.toLowerCase()];
      if (ca) artist = ca;
      return { title: title, artist: artist };
    }

    // --- URL parser ---
    function parseYouTubeUrl(input) {
      var text = input.trim();
      if (!text) return null;
      var m = text.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/);
      if (m) return { videoId: m[1] };
      m = text.match(/[?&]v=([a-zA-Z0-9_-]{11})/);
      if (m) return { videoId: m[1] };
      m = text.match(/\/live\/([a-zA-Z0-9_-]{11})/);
      if (m) return { videoId: m[1] };
      m = text.match(/\/shorts\/([a-zA-Z0-9_-]{11})/);
      if (m) return { videoId: m[1], isShort: true };
      if (/^[a-zA-Z0-9_-]{11}$/.test(text)) return { videoId: text };
      return null;
    }

    // --- Video type detection from title ---
    function detectVideoType(title, urlIsShort) {
      if (urlIsShort) return "short";
      if (/жӯҢжһ |karaoke|[Ss]inging\s*[Ss]tream|жӯҢеӣһ/.test(title)) return "stream";
      if (/[Oo]riginal\s*[Ss]ong|гӮӘгғӘгӮёгғҠгғ«/.test(title)) return "original";
      if (/жӯҢгҒЈгҒҰгҒҝгҒҹ|[Cc]over/.test(title)) return "cover";
      // еҗ«гҖҗгҖ‘дё”еғҸзӣҙж’ӯжЁҷйЎҢ
      if (/гҖҗ.*(?:жӯҢ|sing|#).*гҖ‘/.test(title)) return "stream";
      return "unknown";
    }

    // --- Title parser for single songs ---
    function parseSingleSongTitle(title) {
      // гҖҢжӣІеҗҚ / жӯҢжүӢ Covered by VTuberгҖҚ
      var m = title.match(/^(?:гҖҗ[^гҖ‘]*гҖ‘\s*)?(.+?)\s*\/\s*(.+?)\s+[Cc]overed/);
      if (m) return { title: m[1].trim(), artist: m[2].replace(/\s*[Cc]overed.*$/,"").trim() };
      // гҖҢгҖҗжӯҢгҒЈгҒҰгҒҝгҒҹгҖ‘жӣІеҗҚгҖҗVTuberгҖ‘гҖҚ
      m = title.match(/гҖҗ\s*#?жӯҢгҒЈгҒҰгҒҝгҒҹ\s*гҖ‘\s*(.+?)\s*гҖҗ/);
      if (m) { var s = m[1].trim(); return { title: s.split(/\s*\/\s*/)[0], artist: "" }; }
      // гҖҢгҖҗOriginal SongгҖ‘жӣІеҗҚ / VTuberгҖҚ
      m = title.match(/гҖҗ[^гҖ‘]*[Oo]riginal[^гҖ‘]*гҖ‘\s*(.+?)(?:\s*\/\s*.+)?$/);
      if (m) return { title: m[1].replace(/\s*(?:Official\s*MV|MV).*$/i,"").trim(), artist: "" };
      // гҖҢжӣІеҗҚ / жӯҢжүӢгҖҚ
      m = title.match(/^(.+?)\s*\/\s*(.+?)(?:\s*гҖҗ|$)/);
      if (m) return { title: m[1].trim(), artist: m[2].trim() };
      return { title: title.replace(/\s*гҖҗ.*гҖ‘\s*/g,"").trim(), artist: "" };
    }

    // --- Setlist parser ---
    var TIMESTAMP_RE = /^\s*(\d{1,2}:\d{2}(?::\d{2})?)\s+(.+)$/;
    var RANGE_TS_RE = /^\s*(\d{1,2}:\d{2}(?::\d{2})?)\s*-\s*\d{1,2}:\d{2}(?::\d{2})?\s+(.+)$/;
    var NUMBERING_RE = /^\d{1,3}[\.\)]\s*/;
    var PREFIX_RE = /^(?:гӮўгғігӮігғјгғ«|encore|EN)[пјҡ:\s]+\s*/i;
    var SEPARATORS = [" / ", " пјҸ ", " - ", " вҲ’ ", " гғј "];
    var SKIP_TITLES = ["гӮ№гӮҝгғјгғҲ","start","START","гӮЁгғігғҮгӮЈгғігӮ°","ending","ENDING","йӣ‘и«Ү","гғҲгғјгӮҜ","дј‘жҶ©","й…ҚдҝЎй–Ӣе§Ӣ","й…ҚдҝЎзөӮдәҶ","й–Ӣе§Ӣ","гҒҜгҒҳгҒҫгӮҠ","е§ӢгҒҫгӮҠ","гӮӘгғјгғ—гғӢгғігӮ°гғҲгғјгӮҜ","гӮЁгғігғҮгӮЈгғігӮ°гғҲгғјгӮҜ","MC"];

    function tsToSec(ts) {
      var p = ts.split(":").map(Number);
      if (p.length === 3) return p[0]*3600+p[1]*60+p[2];
      return p[0]*60+p[1];
    }
    function splitTA(text) {
      text = text.trim().replace(PREFIX_RE, "").trim();
      var bm = text.match(/[гҖҢгҖҺ](.+?)[гҖҚгҖҸ]\s*[/пјҸ\-]?\s*(.+)?/);
      if (bm) return [bm[1].trim(), (bm[2]||"").trim()];
      for (var i=0;i<SEPARATORS.length;i++) {
        var lastIdx = text.lastIndexOf(SEPARATORS[i]);
        if (lastIdx >= 0) {
          return [text.slice(0, lastIdx).trim(), text.slice(lastIdx + SEPARATORS[i].length).trim()];
        }
      }
      // еҜ¬й¬Ҷ / : жңҖеҫҢдёҖеҖӢ / еҲҶеүІ
      var slashIdx = text.lastIndexOf(" / ");
      if (slashIdx < 0) slashIdx = text.lastIndexOf(" пјҸ ");
      if (slashIdx >= 0) {
        return [text.slice(0, slashIdx).trim(), text.slice(slashIdx + 3).trim()];
      }
      return [text, ""];
    }
    function parseSetlist(text) {
      var lines = text.split("\n"), songs = [];
      var rangeCount = 0, plainCount = 0;
      for (var i=0;i<lines.length;i++) {
        if (RANGE_TS_RE.test(lines[i])) rangeCount++;
        else if (TIMESTAMP_RE.test(lines[i])) plainCount++;
      }
      var useRange = rangeCount >= 3 && rangeCount >= plainCount * 0.5;
      for (var i=0;i<lines.length;i++) {
        var m = useRange ? lines[i].match(RANGE_TS_RE) : null;
        if (!m) m = lines[i].match(TIMESTAMP_RE);
        if (!m) continue;
        var ts = m[1], sec = tsToSec(ts);
        if (sec === 0) continue;
        var rest = m[2].replace(/[рҹҺөрҹҺ¶рҹҺӨрҹҺёрҹҺ№рҹҺјрҹҺ§вҷӘвҷ«вҳ…вҳҶв–¶в–ә]+/g, "").trim();
        rest = rest.replace(NUMBERING_RE, "").trim();
        var ta = splitTA(rest);
        if (!ta[0] || SKIP_TITLES.indexOf(ta[0]) >= 0) continue;
        songs.push({ timestamp: ts, seconds: sec, title: ta[0], artist: ta[1] });
      }
      return songs;
    }

    // --- DOM ---
    var inputUrl = document.getElementById("input-url");
    var inputSetlist = document.getElementById("input-setlist");
    var btnPreview = document.getElementById("btn-preview");
    var btnSubmit = document.getElementById("btn-submit");
    var videoPreview = document.getElementById("video-preview");
    var previewThumb = document.getElementById("preview-thumb");
    var previewTitle = document.getElementById("preview-title");
    var previewAuthor = document.getElementById("preview-author");
    var videoTypeBadge = document.getElementById("video-type-badge");
    var channelStatus = document.getElementById("channel-status");
    var urlError = document.getElementById("url-error");
    var typeSelector = document.getElementById("type-selector");
    var singleSongSection = document.getElementById("single-song-section");
    var setlistSection = document.getElementById("setlist-section");
    var autoSong = document.getElementById("auto-song");
    var autoArtist = document.getElementById("auto-artist");
    var previewSection = document.getElementById("preview-section");
    var previewCount = document.getElementById("preview-count");
    var previewTbody = document.getElementById("preview-tbody");

    var currentVideoId = "";
    var currentVideoTitle = "";
    var currentChannelId = "";
    var channelAllowed = false;
    var detectedType = "unknown";
    var autoDetected = null; // { title, artist }
    var parsedSongs = [];

    var typeLabels = {
      stream: { zh: "зӣҙж’ӯжӯҢеӣһ", ja: "й…ҚдҝЎ", color: "bg-primary/10 text-primary" },
      cover: { zh: "жҠ•зЁҝеӢ•з•«", ja: "жҠ•зЁҝеӢ•з”»", color: "bg-purple/10 text-purple" },
      original: { zh: "еҺҹеүөжӣІ", ja: "гӮӘгғӘгӮёгғҠгғ«жӣІ", color: "bg-[#eab010]/20 text-[#eab010]" },
      short: { zh: "Short", ja: "Short", color: "bg-accent/10 text-accent" },
      unknown: { zh: "жңӘзҹҘйЎһеһӢ", ja: "дёҚжҳҺ", color: "bg-border text-text-muted" },
    };

    // --- Switch type (auto or manual) ---
    function switchToType(type) {
      detectedType = type;

      // Update badge with i18n key
      var label = typeLabels[type] || typeLabels.unknown;
      var i18nKey = "submit.type_" + type;
      videoTypeBadge.innerHTML =
        '<span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold ' + label.color + '" data-i18n="' + i18nKey + '">' +
        label.zh + '</span>';

      // Highlight active type button
      document.querySelectorAll(".type-btn").forEach(function(btn) {
        var active = btn.getAttribute("data-type-btn") === type;
        btn.classList.toggle("border-primary", active);
        btn.classList.toggle("text-primary", active);
        btn.classList.toggle("font-bold", active);
        btn.classList.toggle("border-border", !active);
      });

      // Show/hide sections
      if (type === "stream" || type === "unknown") {
        setlistSection.classList.remove("hidden");
        singleSongSection.classList.add("hidden");
        autoDetected = null;
        btnSubmit.classList.add("hidden");
      } else {
        setlistSection.classList.add("hidden");
        previewSection.classList.add("hidden");
        autoDetected = parseSingleSongTitle(currentVideoTitle);
        var norm = normalizeSong(autoDetected.title, autoDetected.artist);
        autoDetected.title = norm.title;
        autoDetected.artist = norm.artist;
        autoSong.textContent = autoDetected.title;
        autoArtist.textContent = autoDetected.artist ? "/ " + autoDetected.artist : "";
        singleSongSection.classList.remove("hidden");
        if (channelAllowed) btnSubmit.classList.remove("hidden");
      }

      // йҮҚж–°еҘ—з”Ё i18nпјҲеӢ•ж…Ӣз”ўз”ҹзҡ„ DOM йңҖиҰҒжӣҙж–°пјү
      if (window.__applyI18n) window.__applyI18n();
    }

    // --- Type button clicks ---
    document.querySelectorAll(".type-btn").forEach(function(btn) {
      btn.addEventListener("click", function() {
        switchToType(btn.getAttribute("data-type-btn"));
      });
    });

    // --- URL input ---
    var urlTimer;
    inputUrl.addEventListener("input", function() {
      clearTimeout(urlTimer);
      channelAllowed = false;
      btnSubmit.classList.add("hidden");
      channelStatus.innerHTML = "";
      typeSelector.classList.add("hidden");
      singleSongSection.classList.add("hidden");
      setlistSection.classList.add("hidden");
      previewSection.classList.add("hidden");
      videoTypeBadge.innerHTML = "";

      urlTimer = setTimeout(function() {
        var result = parseYouTubeUrl(inputUrl.value);
        if (!result) {
          videoPreview.classList.add("hidden");
          urlError.textContent = inputUrl.value.trim() ? "з„Ўжі•иҫЁиӯҳзҡ„ YouTube URL" : "";
          urlError.classList.toggle("hidden", !inputUrl.value.trim());
          currentVideoId = "";
          return;
        }
        currentVideoId = result.videoId;
        urlError.classList.add("hidden");

        fetch("https://www.youtube.com/oembed?url=https://youtu.be/" + result.videoId + "&format=json")
          .then(function(r) { return r.json(); })
          .then(function(data) {
            previewThumb.src = data.thumbnail_url || "";
            previewTitle.textContent = data.title || "";
            previewAuthor.textContent = data.author_name || "";
            currentVideoTitle = data.title || "";
            videoPreview.classList.remove("hidden");

            // й »йҒ“й©—иӯү
            var authorName = data.author_name || "";
            channelAllowed = channelNames.indexOf(authorName) >= 0;
            currentChannelId = channelMap[authorName] || "";
            if (channelAllowed) {
              channelStatus.innerHTML =
                '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">' +
                '<svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>' +
                '<span data-i18n="submit.channel_ok">й »йҒ“е·ІиӘҚиӯү</span></span>';
            } else {
              channelStatus.innerHTML =
                '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">' +
                '<svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>' +
                '<span data-i18n="submit.channel_rejected">жӯӨй »йҒ“жңӘй–Ӣж”ҫжҸҗдәӨ</span></span>';
            }

            // йЎҜзӨәйЎһеһӢйҒёж“ҮеҷЁ + иҮӘеӢ•еҒөжё¬й җйҒё
            typeSelector.classList.remove("hidden");
            var autoType = detectVideoType(currentVideoTitle, result.isShort);
            switchToType(autoType);

            if (window.__applyI18n) window.__applyI18n();
          })
          .catch(function() {
            previewThumb.src = "https://img.youtube.com/vi/" + result.videoId + "/default.jpg";
            previewTitle.textContent = result.videoId;
            currentVideoTitle = "";
            videoPreview.classList.remove("hidden");
            setlistSection.classList.remove("hidden");
          });
      }, 500);
    });

    // --- Preview (stream mode) ---
    btnPreview.addEventListener("click", function() {
      parsedSongs = parseSetlist(inputSetlist.value);
      // Normalize all parsed songs
      for (var i=0;i<parsedSongs.length;i++) {
        var n = normalizeSong(parsedSongs[i].title, parsedSongs[i].artist);
        parsedSongs[i].title = n.title;
        parsedSongs[i].artist = n.artist;
      }
      previewTbody.innerHTML = "";
      for (var i=0;i<parsedSongs.length;i++) {
        var s = parsedSongs[i];
        var tr = document.createElement("tr");
        tr.className = "border-b border-border";
        tr.innerHTML =
          '<td class="py-1 px-2 font-mono text-text-muted">' + s.timestamp + '</td>' +
          '<td class="py-1 px-2 font-medium">' + s.title + '</td>' +
          '<td class="py-1 px-2 text-text-muted">' + (s.artist || '<span class="text-[#eab010]">жңӘжҢҮе®ҡ</span>') + '</td>';
        previewTbody.appendChild(tr);
      }
      previewCount.textContent = parsedSongs.length + " жӣІ";
      previewSection.classList.remove("hidden");
      if (parsedSongs.length > 0 && currentVideoId && channelAllowed) {
        btnSubmit.classList.remove("hidden");
      } else {
        btnSubmit.classList.add("hidden");
      }
    });

    // --- Submit ---
    btnSubmit.addEventListener("click", function() {
      if (!currentVideoId || !channelAllowed) return;

      var issueBody, issueTitle;

      if (autoDetected && (detectedType === "cover" || detectedType === "original" || detectedType === "short")) {
        // е–®жӣІжЁЎејҸ
        issueBody =
          "---\n" +
          "video_id: " + currentVideoId + "\n" +
          "video_title: " + currentVideoTitle + "\n" +
          "channel_id: " + currentChannelId + "\n" +
          "type: " + detectedType + "\n" +
          "source: manual\n" +
          "---\n\n" +
          "0:00 " + autoDetected.title + (autoDetected.artist ? " / " + autoDetected.artist : "");
        issueTitle = "[" + detectedType + "] " + autoDetected.title;
      } else {
        // гӮ»гғҲгғӘжЁЎејҸ
        if (parsedSongs.length === 0) return;
        var setlistBody = parsedSongs.map(function(s) {
          return s.timestamp + " " + s.title + (s.artist ? " / " + s.artist : "");
        }).join("\n");
        issueBody =
          "---\n" +
          "video_id: " + currentVideoId + "\n" +
          "video_title: " + currentVideoTitle + "\n" +
          "channel_id: " + currentChannelId + "\n" +
          "type: stream\n" +
          "source: manual\n" +
          "---\n\n" +
          setlistBody;
        issueTitle = "[гӮ»гғҲгғӘ] " + (currentVideoTitle || currentVideoId);
      }

      var url = "https://github.com/" + GITHUB_REPO + "/issues/new?" +
        "labels=setlist-submission" +
        "&title=" + encodeURIComponent(issueTitle) +
        "&body=" + encodeURIComponent(issueBody);

      window.open(url, "_blank");
    });
  </script>
</Base>
