---
import Base from "../layouts/Base.astro";
import { getChannels } from "../lib/data";
import fs from "node:fs";

const channels = getChannels();
const channelNames = channels.map(ch => ch.name);
const channelMap = Object.fromEntries(channels.map(ch => [ch.name, ch.channelId]));
const GITHUB_REPO = "itemx/shinengumi-utawaku";

// Build reverse alias lookup for client-side normalization
const aliasRaw = JSON.parse(fs.readFileSync("data/aliases.json", "utf-8"));
function buildReverseLookup(section: Record<string, string[]>): Record<string, string> {
  const rev: Record<string, string> = {};
  for (const [canonical, aliases] of Object.entries(section)) {
    for (const alias of aliases) {
      rev[alias.toLowerCase()] = canonical;
    }
  }
  return rev;
}
const songAliases = buildReverseLookup(aliasRaw.songs || {});
const artistAliases = buildReverseLookup(aliasRaw.artists || {});
---

<Base title="жҠ•зЁҝ | SEG-V UtaList" description="жүӢеӢ•жҸҗдәӨжӯҢжһ жӣІзӣ®жё…е–®" i18nTitleKey="submit.page_title">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-2" data-i18n="submit.title">жҸҗдәӨжӣІзӣ®жё…е–®</h1>
    <p class="text-text-muted text-sm mb-6" data-i18n="submit.desc">
      иІјдёҠ YouTube еҪұзүҮз¶ІеқҖе’ҢжӣІзӣ®жё…е–®пјҢй җиҰҪзўәиӘҚеҫҢжҸҗдәӨгҖӮ
    </p>

    <!-- YouTube URL -->
    <div class="mb-4">
